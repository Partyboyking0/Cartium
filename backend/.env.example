# Cartium backend environment template
# Copy to backend/.env locally, or add these values in Render's Environment panel.
# Do not commit real credentials.

APP_ENV=development
DEBUG=false
ALLOW_SQLITE_FALLBACK=true

# MySQL connection
# Local example:
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/cartium_clone

# Railway MySQL examples also work. If Railway gives mysql://..., the backend normalizes it.
# DATABASE_URL=mysql+pymysql://USER:PASSWORD@HOST:PORT/DATABASE
# MYSQL_PUBLIC_URL=mysql://USER:PASSWORD@HOST:PORT/DATABASE
# DB_HOST=containers-us-west-xxx.railway.app
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_mysql_password
# DB_NAME=railway

# Comma-separated frontend origins allowed to call this API
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional integrations / demo placeholders
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
GOOGLE_CLIENT_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
ADMIN_EMAIL=admin@cartium.com
ADMIN_PASSWORD=admin123


AI_MODEL_NAME=microsoft/Phi-3-mini-4k-instruct

HUGGINGFACE_API_KEY=
HUGGINGFACE_CHAT_URL=https://router.huggingface.co/v1/chat/completions
HUGGINGFACE_TIMEOUT_SECONDS=90
